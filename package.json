{
  "name": "transitops",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "lint": "bun run --cwd apps/web lint",
    "api:dev": "uv run --cwd apps/api uvicorn app.main:app --reload --port 8000",
    "marketing:dev": "bun run --cwd apps/marketing dev",
    "marketing:build": "bun run --cwd apps/marketing build",
    "marketing:lint": "bun run --cwd apps/marketing lint"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
